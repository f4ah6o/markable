{
  "name": "@f12o/markable",
  "version": "2026.6.1",
  "description": "Headless interaction layer for marking artifacts with structured feedback and rewrite annotations.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f4ah6o/markable.git"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "markable": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./dom": {
      "types": "./dist/dom.d.ts",
      "import": "./dist/dom.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/core.ts src/dom.ts src/vite.ts src/config.ts src/cli.ts --format esm --dts",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "build:demo": "pnpm --filter @f12o/markable-vite-todo-demo build",
    "build:shadcn-admin": "pnpm --filter @f12o/markable-shadcn-admin-demo build"
  },
  "dependencies": {
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "0.22.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plus": "^0.1.24",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.28.1"
}
